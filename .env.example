# =========================================
# Asignador — Variables de Entorno
# Renombrá este archivo a .env.local
# =========================================

# ─── Compartidas (ambos módulos) ──────────
METABASE_URL=https://tu-sitio.metabaseapp.com
METABASE_USERNAME=tu_email@empresa.com
METABASE_PASSWORD=tu_password_seguro

# Google Service Account (compartida)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-servicio@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ─── Módulo Asignaciones Comerciales ─────
# CRM de Leads y Comentarios
GOOGLE_SHEETS_ID=ID_DEL_SHEET_CRM_ASIGNACIONES

# Base Clave (fallback de búsqueda CUIT)
BASE_CLAVE_SHEET_ID=ID_DEL_SHEET_BASE_CLAVE
BASE_CLAVE_SHEET_NAME="Base Cruda"

# ─── Módulo Gestión de Sociedades ─────────
# Sheet con datos de zonas, GADM, exportaciones
SOCIEDADES_SHEETS_ID=ID_DEL_SHEET_GESTION_SOCIEDADES

# API Key alternativa de Metabase (opcional)
# METABASE_API_KEY=tu_api_key_si_la_tenes
